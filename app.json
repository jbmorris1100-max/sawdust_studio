{
  "expo": {
    "name": "InlineIQ",
    "slug": "inline-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.inline.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Take photos of damaged parts for damage reports."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d0d0d"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "name": "InlineIQ",
      "shortName": "InlineIQ",
      "description": "Keep your shop sharp.",
      "themeColor": "#0d0d0d",
      "backgroundColor": "#0d0d0d",
      "lang": "en"
    },
    "extra": {
      "eas": {
        "projectId": "33331172-efed-4765-8d2f-5178e07eac15"
      }
    },
    "plugins": [
      "expo-camera",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Inline to take photos of damaged parts."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00C5CC",
          "sounds": []
        }
      ]
    ],
    "owner": "munkey1100"
  }
}
